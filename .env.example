# Ganti nilai-nilai ini sesuai kebutuhan

# Secret untuk JWT (WAJIB diganti saat produksi)
SECRET_KEY=super-secret-key-change-this
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Gemini API Key
# Jika kosong, aplikasi tetap bisa jalan dengan MODE MOCK (respons AI dummy)
# supaya development/testing tidak terganggu jika kuota/koneksi Gemini bermasalah.
GEMINI_API_KEY=

# Nama model Gemini yang dipakai
GEMINI_TEXT_MODEL=gemini-1.5-flash
GEMINI_VISION_MODEL=gemini-1.5-flash

# Database (default sudah cukup untuk MVP)
DATABASE_URL=sqlite:///./data/pbl_smarthub.db
